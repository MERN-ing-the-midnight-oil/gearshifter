# Copy to .env (repo root) or use packages/organizer-app/.env for Expo apps.
# CLI: supabase login && supabase init && supabase link --project-ref YOUR_PROJECT_REF

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Organizer app only: optional seller Expo web origin so “seller invite” UI can show http(s) links and QR for
# browser testing (e.g. yarn dev:both uses seller on port 8082 — put this in packages/organizer-app/.env).
# EXPO_PUBLIC_SELLER_WEB_INVITE_ORIGIN=http://localhost:8082
SUPABASE_SERVICE_ROLE_KEY=
# DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

# Edge Function create-staff-account (optional): invite link redirect after the user accepts the email invite.
# STAFF_INVITE_REDIRECT_URL=https://your-app.example.com/auth/callback

# Auth emails (invites, password reset) are sent by Supabase Auth. Configure custom SMTP in the
# Dashboard (not in this file): Authentication → SMTP. See docs/supabase-custom-smtp.md
# https://supabase.com/docs/guides/auth/auth-smtp

# Resend API key (optional; local curl/scripts/tests). Same key as Supabase SMTP password. Do not use EXPO_PUBLIC_ — never bundle in the app.
RESEND_API_KEY=

# Seller dashboard base URL (no trailing slash). Used in SMS hook + deep links (defaults to https://gearswap.app in code).
# EXPO_PUBLIC_SELLER_DASHBOARD_ORIGIN=https://gearswap.app

# Edge Function `auth-send-sms` (optional): Supabase Auth “Send SMS” hook — Twilio + dashboard link in body.
# AUTH_SEND_SMS_HOOK_SECRET=   # Dashboard → Auth → Hooks (same format as other hook secrets)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+1xxxxxxxxxx
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxx   # optional alternative to TWILIO_FROM_NUMBER
# SELLER_PUBLIC_DASHBOARD_ORIGIN=https://gearswap.app   # used by the hook (Edge env, not EXPO_PUBLIC_)
